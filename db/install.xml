<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/aihub/db" VERSION="20260628"
    COMMENT="XMLDB file for Moodle local/aihub"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_aihub_log" COMMENT="One row per AI generation request; usage auditing and self-service history">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="component" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="provider" TYPE="char" LENGTH="40" NOTNULL="true"/>
        <FIELD NAME="model" TYPE="char" LENGTH="100" NOTNULL="false"/>
        <FIELD NAME="success" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_user" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_component" UNIQUE="false" FIELDS="component"/>
        <INDEX NAME="idx_timecreated" UNIQUE="false" FIELDS="timecreated"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
